# ─── PlanView Environment Configuration ───
# Copy to .env and fill in production values

# ─── Database ───
DB_PASSWORD=planview_dev_secret_2026
DATABASE_URL=postgresql://planview:planview_dev_secret_2026@localhost:5432/planview

# ─── Redis ───
REDIS_PASSWORD=planview_redis_dev
REDIS_URL=redis://:planview_redis_dev@localhost:6379

# ─── JWT Auth ───
# CRITICAL: Change these in production. Use `openssl rand -hex 64` to generate.
JWT_SECRET=planview_jwt_dev_secret_change_in_production
JWT_REFRESH_SECRET=planview_refresh_dev_secret_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── API Server ───
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Web App ───
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# ─── Stripe Billing (optional) ───
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_enterprise_yearly

# ─── Razorpay Billing (primary) ───
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=razorpay_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret_placeholder
# Create plans at https://dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_PRO_MONTHLY=plan_pro_monthly
RAZORPAY_PLAN_PRO_YEARLY=plan_pro_yearly
RAZORPAY_PLAN_ENTERPRISE_MONTHLY=plan_enterprise_monthly
RAZORPAY_PLAN_ENTERPRISE_YEARLY=plan_enterprise_yearly

# ─── Frontend Billing ───
VITE_RAZORPAY_KEY_ID=rzp_test_placeholder

# ─── Email Notifications ───
# Provider: 'sendgrid' | 'log' (log = dev mode, prints to console)
EMAIL_PROVIDER=log
EMAIL_FROM=PlanView <noreply@planview.app>
SENDGRID_API_KEY=SG.placeholder

# ─── App URL (for email links) ───
APP_URL=http://localhost:5173
